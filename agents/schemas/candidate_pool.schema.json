{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CandidatePool",
  "type": "object",
  "required": ["candidates"],
  "properties": {
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "track_b", "track_c", "track_d", "track_e", "track_f", "safety_flag"],
        "properties": {
          "name": { "type": "string" },
          "track_b": {
            "type": "object",
            "required": ["community_sentiment", "confirmed_issues", "sources"],
            "properties": {
              "community_sentiment": { "type": "string", "enum": ["positive", "mixed", "negative", "insufficient_data"] },
              "confirmed_issues": { "type": "array", "items": { "type": "string" } },
              "sources": { "type": "array", "items": { "type": "string" } }
            }
          },
          "track_c": {
            "type": "object",
            "required": ["specs", "sources_checked", "conditional_specs", "flags"],
            "properties": {
              "specs": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "required": ["status"],
                  "properties": {
                    "status": { "type": "string", "enum": ["verified", "diverges", "no_source", "inconclusive"] },
                    "claimed": { "type": ["string", "null"] },
                    "measured": { "type": ["string", "null"] },
                    "source": { "type": ["string", "null"] }
                  }
                },
                "minProperties": 1
              },
              "sources_checked": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 5,
                "description": "All sources consulted for spec verification, including those that returned no results. Minimum 5 — one per exhaustion step (measured search, community/forum, YouTube/teardown, competitor comparison, manufacturer spec page)."
              },
              "conditional_specs": { "type": "array", "items": { "type": "string" } },
              "flags": { "type": "array", "items": { "type": "string" } }
            }
          },
          "track_d": {
            "type": "object",
            "required": ["current_price", "currency", "retailer", "retailer_url", "in_stock", "price_history", "sale_eligible", "consider_waiting"],
            "properties": {
              "current_price": { "type": "number" },
              "currency": { "type": "string" },
              "retailer": { "type": "string" },
              "retailer_url": { "type": "string", "minLength": 1, "description": "Direct URL to the retailer product listing, verified live" },
              "in_stock": { "type": "boolean", "description": "Whether the product was in stock at time of research" },
              "price_history": { "type": "string" },
              "sale_eligible": { "type": "boolean" },
              "consider_waiting": {}
            }
          },
          "track_e": {
            "type": "object",
            "required": ["recall_status", "lifecycle_status"],
            "properties": {
              "recall_status": { "type": "string", "enum": ["clear", "recalled", "check_failed"] },
              "recall_source": { "type": ["string", "null"] },
              "lifecycle_status": { "type": "string", "enum": ["current", "discontinued", "successor_imminent", "successor_announced"] }
            }
          },
          "track_f": {
            "type": "object",
            "required": ["model_verified", "url_verified", "regional_spec_match", "price_verified_live", "price_at_generation"],
            "properties": {
              "model_verified": { "type": "boolean" },
              "url_verified": { "type": "boolean" },
              "regional_spec_match": { "type": "boolean" },
              "price_verified_live": { "type": "boolean", "description": "Whether the price was confirmed by fetching the live retailer page immediately before generation" },
              "price_at_generation": { "type": ["number", "null"], "description": "The price confirmed live at generation time. Null if page could not be fetched." },
              "notes": { "type": ["string", "null"] }
            }
          },
          "safety_flag": { "type": "boolean" }
        }
      },
      "minItems": 1,
      "maxItems": 15
    }
  },
  "additionalProperties": false
}
