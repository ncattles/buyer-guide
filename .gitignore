.DS_Store
.playwright-mcp/

# Node build artifacts (generation agent installs docx at project root)
node_modules/
package.json
package-lock.json

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Loose screenshots (should live in runs/[timestamp]/screenshots/)
*.png
*.jpg
*.jpeg

# Guide run artifacts
runs/*/
!runs/.gitkeep

# Generated PDFs
guides/*.pdf
!guides/.gitkeep
